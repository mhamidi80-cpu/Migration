# --- General Configuration ---
aws_region  = "us-east-1"
environment = "Dev"

# --- Networking ---
vpc_cidr            = "172.16.0.0/16"
public_subnet_cidr  = "172.16.1.0/24"
private_subnet_cidr = "172.16.2.0/24"

# --- Database Credentials ---
# Use the naming convention: m.hamidi
db_username = "m.hamidi"

# DO NOT put real passwords in this example file.
# Users should copy this file to terraform.tfvars and change the value below.
db_password = "password-goes-here"

# --- Compute ---
instance_type = "t3.micro"

